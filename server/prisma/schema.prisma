generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String  @id @default(uuid())
  firstName       String  @map("first_name")
  lastName        String?  @map("last_name")
  email           String  @unique
  password        String
  salt            String
  profileImageURL String? @map("profile_image_url")

  @@map("users")
}
